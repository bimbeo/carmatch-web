    },
    {
      "src": "/(cars|vehicles|fleet|danh-sach-xe|thue-xe)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe" }
    },
    {
      "src": "/thue-xe-tu-lai-ecopark/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/di-dau/ecopark" }
    },
    {
      "src": "/taxi-san-bay-noi-bai/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe-san-bay-noi-bai" }
    },
    {
      "src": "/sitemap\\.rss",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/rss.xml" }
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/registerSW\\.js",
      "dest": "/registerSW.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/api/promo-list/?",
      "dest": "/api/promos?action=list"
    },
    {
      "src": "/api/promo-validate/?",
      "dest": "/api/promos?action=validate"
    },
    { "src": "/tai-khoan/?", "dest": "/tai-khoan/index.html" },
    { "src": "/chao-ban/?", "dest": "/chao-ban/index.html" },
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/xe/([^/]+)/?", "status": 404, "dest": "/404.html" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
