{
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/brand/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(favicon.ico|favicon.svg|favicon-16x16.png|favicon-32x32.png|apple-touch-icon.png|android-chrome-192x192.png|android-chrome-512x512.png)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/site.webmanifest",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "continue": true
    },
    {
      "src": "/faq-thue-xe-tu-lai-ha-noi",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/faq" }
    },
    {
      "src": "/sitemap\\.(xml|rss)",
      "has": [{ "type": "host", "value": "blog.carmatch.vn" }],
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/sitemap.xml" }
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "blog.carmatch.vn" }],
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/blogs/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/blog/hello-world/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/blog/kinh-nghiem-thue-xe-tu-lai-ha-noi-tranh-lua-dao/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog/kinh-nghiem-thue-xe-tu-lai-ha-noi" }
    },
    {
      "src": "/guilde/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/di-dau" }
    },
    {
      "src": "/policy/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/chinh-sach" }
    },
    {
      "src": "/car-sharing/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/hop-tac" }
    },
    {
      "src": "/car/([^/]+)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe" }
    },
    {
      "src": "/(ve-chung-toi|about|gioi-thieu-carmatch)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/gioi-thieu" }
    },
    {
      "src": "/(chinh-sach-bao-mat|dieu-khoan|privacy|terms)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/chinh-sach" }
    },
    {
      "src": "/(booking-confirm|booking-confirmation|confirm-booking)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/dat-xe" }
    },
    {
      "src": "/(cars|vehicles|fleet|danh-sach-xe|thue-xe)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe" }
    },
    {
      "src": "/sitemap\\.rss",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/sitemap.xml" }
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/registerSW\\.js",
      "dest": "/registerSW.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/blog/([^/]+)/?",
      "dest": "/api/posts?slug=$1&format=html"
    },
    {
      "src": "/blog/?",
      "dest": "/api/posts?format=html"
    },
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
