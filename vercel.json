{
  "routes": [
    {
      "src": "/sitemap\\.(xml|rss)",
      "has": [{ "type": "host", "value": "blog.carmatch.vn" }],
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/sitemap.xml" }
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "blog.carmatch.vn" }],
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "carmatch.vn" }],
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/$1" }
    },
    {
      "src": "/blogs/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/blog/hello-world/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog" }
    },
    {
      "src": "/blog/kinh-nghiem-thue-xe-tu-lai-ha-noi-tranh-lua-dao/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/blog/kinh-nghiem-thue-xe-tu-lai-ha-noi" }
    },
    {
      "src": "/blog/thue-xe-7-cho-tu-lai-ha-noi-gia-bao-nhieu/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/thue-xe-tu-lai-ha-noi" }
    },
    {
      "src": "/guilde/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/di-dau" }
    },
    {
      "src": "/policy/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/chinh-sach" }
    },
    {
      "src": "/car-sharing/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/hop-tac" }
    },
    {
      "src": "/car/([^/]+)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe" }
    },
    {
      "src": "/xe/vinfast-vf3-2024-30m-02770/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe/vinfast-vf3-2024" }
    },
    {
      "src": "/xe/vinfast-vf7s-2025/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe/vinfast-vf7s-2025-30l91487" }
    },
    {
      "src": "/(ve-chung-toi|about|gioi-thieu-carmatch)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/gioi-thieu" }
    },
    {
      "src": "/(chinh-sach-bao-mat|dieu-khoan|privacy|terms)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/chinh-sach" }
    },
    {
      "src": "/(booking-confirm|booking-confirmation|confirm-booking)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/dat-xe" }
    },
    {
      "src": "/(cars|vehicles|fleet|danh-sach-xe|thue-xe)/?",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/xe" }
    },
    {
      "src": "/sitemap\\.rss",
      "status": 301,
      "headers": { "Location": "https://www.carmatch.vn/sitemap.xml" }
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/service-worker\\.js",
      "dest": "/service-worker.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "Service-Worker-Allowed": "/",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/registerSW\\.js",
      "dest": "/registerSW.js",
      "headers": {
        "Cache-Control": "no-store, max-age=0",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/(thue-xe-tu-lai-ha-noi|thue-xe-tu-lai-vinhomes-ocean-park|thue-xe-tu-lai-times-city|thue-xe-tu-lai-vinhomes-smart-city|thue-xe-tu-lai-ecopark|thue-xe-tu-lai-the-manor|faq-thue-xe-tu-lai-ha-noi)/?",
      "dest": "/$1/index.html"
    },
    {
      "src": "/blog/([^/]+)/?",
      "dest": "/api/posts?slug=$1&format=html"
    },
    {
      "src": "/blog/?",
      "dest": "/api/posts?format=html"
    },
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "status": 404, "dest": "/404.html" }
  ]
}
