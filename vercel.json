      "headers": { "Location": "https://www.carmatch.vn/blog/thue-xe-tu-lai-ha-noi-gia-bao-nhieu" }
    },
    {
      "src": "/blog/([^/]+)/?",
      "dest": "/blog/$1/index.html"
    },
    {
      "src": "/blog/?",
      "dest": "/blog/index.html"
    },
    {
      "src": "/(ve-chung-toi|about|gioi-thieu-carmatch)/?",
